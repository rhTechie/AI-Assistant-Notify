# Required. Full Feishu custom bot webhook URL.
FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/replace-with-your-webhook"

# Required when your bot enables keyword security.
# This value must exactly match the keyword configured in Feishu bot settings.
FEISHU_KEYWORD="Codex审批"

# Path to the Codex global TUI log watched by this project.
CODEX_TUI_LOG_PATH="$HOME/.codex/log/codex-tui.log"

# Advanced: dedup cooldown in seconds for the same approval event.
# Usually you do not need to change this.
CODEX_APPROVAL_NOTIFY_COOLDOWN=30

# Advanced: time window for linking recent context to a notification.
# Usually you do not need to change this.
CODEX_APPROVAL_CONTEXT_WINDOW=120

# Set to 1 to write debug traces while matching log lines and sending notifications.
CODEX_APPROVAL_WATCH_DEBUG=0

# Optional debug log file path. Used only when CODEX_APPROVAL_WATCH_DEBUG=1.
# CODEX_APPROVAL_WATCH_DEBUG_LOG="/tmp/codex-feishu-notify/watch-debug.log"

# Optional error log file path for notification failures and watcher errors.
# CODEX_APPROVAL_WATCH_ERROR_LOG="/tmp/codex-feishu-notify/watch-errors.log"

# Advanced: if a new Codex approval event is missed, add its event name here.
# Example: CODEX_APPROVAL_EXTRA_EVENTS="some_new_event"
# CODEX_APPROVAL_EXTRA_EVENTS=""
